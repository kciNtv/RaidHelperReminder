# Copy this file to secrets.local.env and fill in the real values.
# secrets.local.env is listed in .gitignore and must NEVER be committed.

# From https://discord.com/developers/applications -> your app -> Bot -> Reset Token
DISCORD_BOT_TOKEN=paste-bot-token-here

# From your Discord server: type /apikey and pick "show" (Raid-Helper answers privately)
RAIDHELPER_API_KEY=paste-raid-helper-api-key-here
